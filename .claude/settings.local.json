{
  "permissions": {
    "allow": [
      "*",
      "Bash(cp -r /c/Users/Sidhartha/claude-spellbook/skills/ai-engineer /c/Users/Sidhartha/.claude/skills/)",
      "Bash(cp -r /c/Users/Sidhartha/claude-spellbook/skills/azure /c/Users/Sidhartha/.claude/skills/)",
      "Bash(cp -r /c/Users/Sidhartha/claude-spellbook/skills/complex-doc-rag /c/Users/Sidhartha/.claude/skills/)",
      "Bash(mkdir -p /c/Users/Sidhartha/.claude/agents)",
      "Bash(cp /c/Users/Sidhartha/claude-spellbook/.claude/agents/* /c/Users/Sidhartha/.claude/agents/)",
      "Bash(mkdir -p /c/Users/Sidhartha/.claude/commands)",
      "Bash(cp /c/Users/Sidhartha/claude-spellbook/.claude/commands/* /c/Users/Sidhartha/.claude/commands/)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "prettier --write $CLAUDE_FILE_PATH",
            "if": "Write(**/*.ts)"
          },
          {
            "type": "command",
            "command": "prettier --write $CLAUDE_FILE_PATH",
            "if": "Write(**/*.svelte)"
          },
          {
            "type": "command",
            "command": "black $CLAUDE_FILE_PATH",
            "if": "Write(**/*.py)"
          },
          {
            "type": "command",
            "command": "gofmt -w $CLAUDE_FILE_PATH",
            "if": "Write(**/*.go)"
          },
          {
            "type": "command",
            "command": "rustfmt $CLAUDE_FILE_PATH",
            "if": "Write(**/*.rs)"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "eslint --fix $CLAUDE_FILE_PATH",
            "if": "Edit(**/*.ts)"
          },
          {
            "type": "command",
            "command": "eslint --fix $CLAUDE_FILE_PATH",
            "if": "Edit(**/*.svelte)"
          },
          {
            "type": "command",
            "command": "ruff check --fix $CLAUDE_FILE_PATH",
            "if": "Edit(**/*.py)"
          },
          {
            "type": "command",
            "command": "golangci-lint run $CLAUDE_FILE_PATH",
            "if": "Edit(**/*.go)"
          },
          {
            "type": "command",
            "command": "cargo clippy --fix --allow-dirty 2>/dev/null || true",
            "if": "Edit(**/*.rs)"
          },
          {
            "type": "command",
            "command": "markdownlint --fix $CLAUDE_FILE_PATH 2>/dev/null || true",
            "if": "Edit(**/*.md)"
          },
          {
            "type": "command",
            "command": "bash -c 'FILE=\"$CLAUDE_FILE_PATH\"; echo \"--- Skill format check: $FILE ---\"; ERRORS=0; head -1 \"$FILE\" | grep -q \"^---\" || { echo \"FAIL: Missing frontmatter\"; ERRORS=1; }; grep -q \"^name:\" \"$FILE\" || { echo \"FAIL: Missing name:\"; ERRORS=1; }; grep -q \"^description:\" \"$FILE\" || { echo \"FAIL: Missing description:\"; ERRORS=1; }; grep -q \"## When to Activate\" \"$FILE\" || { echo \"FAIL: Missing When to Activate\"; ERRORS=1; }; grep -q \"## Checklist\" \"$FILE\" || { echo \"FAIL: Missing Checklist\"; ERRORS=1; }; grep -q \"\\- \\[ \\]\" \"$FILE\" || { echo \"FAIL: No checklist items\"; ERRORS=1; }; if [ $ERRORS -eq 0 ]; then echo \"PASS\"; fi'",
            "if": "Edit(skills/*/skill.md)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[$(date +'%Y-%m-%d %H:%M:%S')] cmd ran\" >> .claude/command.log 2>/dev/null || true",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "git status"
          }
        ]
      }
    ],
    "Stop": []
  }
}
